# Cursor Agent CLI - main brain (replaces Ollama)
# Install: curl https://cursor.com/install -fsS | bash
CURSOR_AGENT_PATH=cursor-agent
# CURSOR_AGENT_TIMEOUT=300

# ===== Local mode only (no Zep Cloud, no Ollama) =====
USE_LOCAL_MODE=true

# ===== Graph entity limit (hard cap for simulation agents) =====
# MAX_ENTITY_LIMIT=50

# ===== OASIS simulation rounds (default 300 in config) =====
# OASIS_DEFAULT_MAX_ROUNDS=300

# ===== Default language: en (English) or zh (Chinese) =====
# MIROFISH_DEFAULT_LANGUAGE=en
